# 环境变量配置文件
# 复制此文件为 .env 并修改相应配置


# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

#URL配置
ISSUER_URL=http://localhost:5000
REDIRECT_URL=http://localhost:5050
ORIGINS_URL=http://localhost:8080
JWR_URL=http://localhost:5000
RBAC_URL=http://localhost:31124
MCP_URL=http://localhost:31445

# 应用配置
APP_NAME=User-agent
APP_ENV=development  # development, testing, production
DEBUG=true
SECRET_KEY=your-secret-key-here-change-in-production

# 服务器配置
HOST=0.0.0.0
PORT=5050
WEBSOCKET_PORT=9090

# 日志配置
LOG_LEVEL=INFO

# 安全配置
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256

# CORS配置
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]

# 文件上传配置
MAX_UPLOAD_SIZE=10485760  # 10MB
ALLOWED_EXTENSIONS=["jpg", "jpeg", "png", "pdf", "txt"]
