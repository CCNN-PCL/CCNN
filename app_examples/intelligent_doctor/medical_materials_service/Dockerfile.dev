# 开发环境Dockerfile
FROM golang:1.23.0-alpine

# 安装开发工具
RUN echo -e "https://mirrors.tuna.tsinghua.edu.cn/alpine/v3.20/main\nhttps://mirrors.tuna.tsinghua.edu.cn/alpine/v3.20/community" > /etc/apk/repositories && \
    apk update && \
    apk add --no-cache \
    gcc \
    musl-dev \
    musl-utils \
    libc6-compat \
    git \
    curl \
    bash \
    make \
    ca-certificates \
    tzdata

# 安装air用于热重载
RUN go install github.com/cosmtrek/air@latest

# 设置时区
ENV TZ=Asia/Shanghai

WORKDIR /app

# 设置Go环境变量
ENV GOPROXY=https://goproxy.cn,direct \
    CGO_ENABLED=1 \
    GO111MODULE=on

# 复制go.mod和go.sum
COPY go.mod go.sum ./
RUN go mod download

# 复制源代码
COPY . .

# 暴露端口
EXPOSE 8080 2345

# 默认命令
CMD ["air", "-c", ".air.toml"]
